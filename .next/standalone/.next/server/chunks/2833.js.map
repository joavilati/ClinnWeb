  import { fillMetadataSegment } from 'next/dist/lib/metadata/get-metadata-route'

  export default async (props) => {
    const imageData = {"type":"image/png","sizes":"1024x1024"}
    const imageUrl = fillMetadataSegment(".", await props.params, "apple-icon.png")

    return [{
      ...imageData,
      url: imageUrl + "?38de1d5963a19d0f",
    }]
  }